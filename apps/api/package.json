{
  "name": "api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch app.ts",
    "build": "tsup app.ts --format esm,cjs --out-dir dist",
    "start": "node dist/app.js",
    "lint": "eslint .",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "compression": "^1.8.0",

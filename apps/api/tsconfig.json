{
    // "extends": "@repo/typescript-config/base.json",
    "compilerOptions": {
        "target": "ES2016",
        "module": "CommonJS",
        "resolveJsonModule": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "skipLibCheck": true,
        "outDir": "dist",
        "rootDir": "./",
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "./*"
            ],
        }
    },
    "include": [
        "**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ],
}
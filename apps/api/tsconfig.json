{
    "extends": "@repo/typescript-config/base.json",
    "compilerOptions": {
        "esModuleInterop": true,
        "outDir": "./dist",
        "rootDir": "./",
        "baseUrl": ".",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "paths": {
            "@/*": [
                "./*"
            ],
        }
    },
    "include": [
        "**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ],
}
# ****************************** Environment Variables for the Applications ****************************** #
#                                                                                                          #
# - This file contains sensitive information and should not be shared publicly.                            #
# - Make sure to add this file to your .gitignore to prevent it from being pushed to version control.      #
# - Use environment variables to manage sensitive data securely.                                           #
# - Ensure that the values are correct and match your local or production environment settings.            #
# - For more information on how to use .gitignore, see https://help.github.com/articles/ignoring-files/    #
#                                                                                                          #
# ******************************************************************************************************** #

NODE_ENV=""
# You can use: development, production, etc.


# - DATABASE *********************************************************************************************
# 
MONGODB_URL="mongodb+srv://username:password@host:port/database?retryWrites=true&w=majority"
# Replace username and password with your actual MongoDB credentials.
# Replace host, port, and database with your actual MongoDB connection details.
# 
# ********************************************************************************************************


# - SHARED ***********************************************************************************************
# 
# Base URL for web application
NEXT_PUBLIC_BASE_URL="http://localhost:3002"
# API URL for api application
NEXT_PUBLIC_API_URL="http://localhost:3003"
# Port for web application
NEXT_PUBLIC_BASE_PORT=3002
# Port for api application
API_PORT=3003
#
# ********************************************************************************************************


# - EMAIL ************************************************************************************************
#
# SMTP configuration for sending emails
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER="example@example.com"
SMTP_PASS="password"
#
# ********************************************************************************************************


# - JWT **************************************************************************************************
#
# JWT secret key for signing tokens
JWT_SECRET="your_jwt_secret_key"
# JWT expiration time (in seconds)
JWT_EXPIRATION=3600
# JWT refresh token expiration time (in seconds)
JWT_REFRESH_EXPIRATION=86400
#
# ********************************************************************************************************
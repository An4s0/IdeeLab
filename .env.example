# - DATABASE *********************************************************************************************
# 
MONGODB_URL="mongodb+srv://username:password@host:port/database?retryWrites=true&w=majority"
# Replace username and password with your actual MongoDB credentials.
# Replace host, port, and database with your actual MongoDB connection details.
# 
# ********************************************************************************************************

# - SHARED ***********************************************************************************************
# 
# Base URL for web application
NEXT_PUBLIC_BASE_URL="http://localhost:3002"
# API URL for api application
NEXT_PUBLIC_API_URL="http://localhost:3003"
# Port for web application
NEXT_PUBLIC_BASE_PORT=3002
# Port for api application
API_PORT=3003
#
